---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import headerImage from '../assets/hero-startseite.jpg';
---

<BaseLayout
  title="Kontakt"
  description="Kontakt zu Piitoo's Bootsservice in Oberteuringen am Bodensee. Telefon, E-Mail, Adresse — kostenloses und unverbindliches Angebot."
>
  <!-- HEADER -->
  <header class="page-header">
    <div class="page-header-bg" aria-hidden="true">
      <Image
        class="page-header-img"
        src={headerImage}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <div class="page-header-overlay"></div>
    </div>
    <div class="container container-narrow page-header-content">
      <p class="eyebrow reveal reveal-1">Schreiben Sie uns</p>
      <h1 class="reveal reveal-2">
        Sprechen Sie uns<br /><em>einfach an.</em>
      </h1>
      <p class="lead reveal reveal-3">
        Rufen Sie an oder schreiben Sie kurz. Wir kommen zu Ihrem Boot,
        schauen uns alles an und geben Ihnen eine ehrliche Einschätzung. Kostenlos.
      </p>
    </div>
  </header>

  <!-- CONTACT GRID -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">

        <!-- Linke Spalte: Direktkontakt -->
        <div class="contact-direct">
          <p class="eyebrow">Direkter Draht</p>
          <h2>Am schnellsten per Telefon.</h2>
          <p class="lead">Wir sind meistens in der Werkstatt oder draußen am Boot. Eine kurze Nachricht geht natürlich auch.</p>

          <div class="contact-methods">
            <a href="tel:+4915234692127" class="contact-method">
              <span class="contact-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
                </svg>
              </span>
              <div>
                <span class="contact-label">Mobil</span>
                <span class="contact-value">0152 34692127</span>
              </div>
            </a>

            <a href="tel:+4975413773099" class="contact-method">
              <span class="contact-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 7h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7zM7 7V5a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/>
                </svg>
              </span>
              <div>
                <span class="contact-label">Festnetz</span>
                <span class="contact-value">07541 3773099</span>
              </div>
            </a>

            <a href="mailto:piitoosbootsservice@gmail.com" class="contact-method">
              <span class="contact-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </span>
              <div>
                <span class="contact-label">E-Mail</span>
                <span class="contact-value">piitoosbootsservice@gmail.com</span>
              </div>
            </a>
          </div>
        </div>

        <!-- Rechte Spalte: Werkstatt -->
        <aside class="contact-card">
          <p class="eyebrow eyebrow-light">Werkstatt</p>
          <h3>Peter<br /><em>Kowalewski</em></h3>
          <hr class="divider-wave" />
          <address>
            <strong>Peter Kowalewski</strong><br />
            Gelernter Bootsbauer
            <br /><br />
            Tavernengasse 4<br />
            88094 Oberteuringen<br />
            Bodenseekreis
          </address>

          <a
            href="https://www.google.com/maps/search/?api=1&query=Tavernengasse+4,+88094+Oberteuringen"
            class="map-link"
            target="_blank"
            rel="noopener"
          >
            Auf Google Maps zeigen →
          </a>
        </aside>

      </div>
    </div>
  </section>

  <!-- HINWEIS -->
  <section class="contact-note">
    <div class="container container-narrow">
      <p>
        Schreiben oder rufen Sie kurz an, am besten mit Bootstyp, Liegeplatz und was Sie brauchen.
        Dann melden wir uns und machen einen Termin.
      </p>
    </div>
  </section>

  <style>
    .page-header {
      position: relative;
      padding: var(--space-7) 0 var(--space-6);
      min-height: 44vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      text-align: center;
      color: var(--color-white);
    }

    .page-header-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .page-header-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      display: block;
    }

    .page-header-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(10, 28, 46, 0.45) 0%,
        rgba(10, 28, 46, 0.3) 45%,
        rgba(10, 28, 46, 0.7) 100%
      );
    }

    .page-header-content {
      position: relative;
      z-index: 1;
    }

    .page-header .eyebrow {
      justify-content: center;
      color: #ffd89c;
    }

    .page-header h1 {
      color: var(--color-white);
      text-shadow: 0 2px 28px rgba(0, 0, 0, 0.45);
    }

    .page-header h1 em {
      color: var(--color-orange);
      font-style: normal;
    }

    .page-header .lead {
      margin: var(--space-3) auto 0;
      color: rgba(255, 255, 255, 0.9);
      text-shadow: 0 1px 12px rgba(0, 0, 0, 0.4);
    }

    .contact-section {
      padding: var(--space-5) 0 var(--space-6);
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: var(--space-5);
      align-items: start;
    }

    @media (max-width: 900px) {
      .contact-grid {
        grid-template-columns: 1fr;
      }
    }

    /* Direkter Kontakt */
    .contact-direct h2 {
      margin-bottom: var(--space-2);
    }

    .contact-methods {
      margin-top: var(--space-4);
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }

    .contact-method {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--space-3);
      align-items: center;
      padding: var(--space-3);
      background: var(--color-paper);
      border: 1px solid rgba(17, 17, 17, 0.08);
      border-radius: var(--radius-md);
      transition: all var(--transition);
      color: var(--color-ink);
    }

    .contact-method:hover {
      border-color: var(--color-orange);
      transform: translateX(4px);
      box-shadow: var(--shadow-soft);
    }

    .contact-icon {
      display: inline-flex;
      width: 48px;
      height: 48px;
      align-items: center;
      justify-content: center;
      background: var(--color-fog);
      color: var(--color-orange);
      border-radius: 50%;
      flex-shrink: 0;
    }

    .contact-method:hover .contact-icon {
      background: var(--color-orange);
      color: var(--color-white);
    }

    .contact-method div {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }

    .contact-label {
      font-size: var(--fs-xs);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .contact-value {
      font-family: var(--font-display);
      font-size: var(--fs-md);
      font-weight: 600;
      color: var(--color-ink);
    }

    /* Werkstatt-Karte */
    .contact-card {
      background: var(--color-charcoal);
      color: var(--color-white);
      padding: var(--space-4);
      border-radius: var(--radius-md);
      position: relative;
      overflow: hidden;
    }

    .contact-card::before {
      content: '';
      position: absolute;
      right: -100px;
      bottom: -100px;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(224, 112, 53, 0.2) 0%, transparent 60%);
      pointer-events: none;
    }

    .eyebrow-light {
      color: var(--color-orange);
    }

    .contact-card h3 {
      color: var(--color-white);
      margin-bottom: 0;
    }

    .contact-card address {
      font-style: normal;
      line-height: 1.7;
      font-size: var(--fs-base);
      color: rgba(255, 255, 255, 0.8);
      margin-bottom: var(--space-3);
    }

    .contact-card address strong {
      color: var(--color-white);
      font-weight: 700;
    }

    .map-link {
      display: inline-block;
      color: var(--color-orange);
      font-size: var(--fs-sm);
      font-weight: 600;
      border-bottom: 1px solid transparent;
      transition: all var(--transition);
    }

    .map-link:hover {
      color: var(--color-white);
      border-bottom-color: var(--color-white);
    }

    /* Hinweis */
    .contact-note {
      padding: 0 0 var(--space-6);
      text-align: center;
    }

    .contact-note p {
      font-size: var(--fs-sm);
      color: var(--text-secondary);
      max-width: 56ch;
      margin: 0 auto;
      line-height: 1.7;
    }

    .contact-note strong {
      color: var(--color-ink);
    }
  </style>
</BaseLayout>
