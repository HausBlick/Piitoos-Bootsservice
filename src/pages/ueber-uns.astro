---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import naehtischImage from '../assets/naehtisch.jpg';
import heroImage from '../assets/hero-startseite.jpg';
const baseUrl = import.meta.env.BASE_URL;
const url = (p: string) => `${baseUrl}${p}`.replace('//', '/');
---

<BaseLayout
  title="Über uns"
  description="Peter Kowalewski — gelernter Bootsbauer, Segler und Angler. Die Geschichte hinter Piitoo's Bootsservice am Bodensee."
>
  <article class="story">
    <header class="story-header">
      <div class="story-header-bg" aria-hidden="true">
        <Image
          class="story-header-img"
          src={heroImage}
          alt=""
          widths={[768, 1280, 1920]}
          sizes="100vw"
          loading="eager"
          fetchpriority="high"
        />
        <div class="story-header-overlay"></div>
      </div>
      <div class="container container-narrow story-header-content">
        <p class="eyebrow reveal reveal-1">Die Geschichte</p>
        <h1 class="reveal reveal-2">
          Vom Wasser<br /><em>zur Werkstatt.</em>
        </h1>
        <p class="story-meta reveal reveal-3">Piitoo's Bootsservice · Seit 2020</p>
      </div>
    </header>

    <section class="story-body">
      <div class="container story-layout">
        <div class="story-prose">
          <p>
            Als gelernter Bootsbauer habe ich meine Leidenschaft für Boote und das Handwerk
            früh entdeckt. Im Jahr 2020 gründete ich meine eigene bootsspezifische Näherei
            sowie einen umfassenden Bootsservice.
          </p>
          <p>
            Durch meine Kindheit auf dem Wasser und meine langjährige Erfahrung als Angler,
            Segler und Bootsbauer — sowie als Ausbilder unter Segel und Motor — war der Bezug
            zum Wasser und den damit in Verbindung stehenden Booten immer ein zentraler
            Bestandteil meines Lebens.
          </p>
          <p>
            Begonnen hat alles im kleinen Rahmen in den eigenen vier Wänden.
          </p>
          <p>
            Nun bieten wir als kleines Team mit viel Liebe zum Detail, handwerklichem Geschick,
            Können und echter Leidenschaft individuelle Lösungen rund ums Boot an.
          </p>
        </div>

        <figure class="story-feature">
          <Image
            src={naehtischImage}
            alt="Industrienähmaschine in der Werkstatt mit Gurtband, Schere und Stecknadeln während der Anfertigung einer Persenning"
            widths={[480, 768, 1100]}
            sizes="(max-width: 820px) 100vw, 520px"
            loading="lazy"
          />
        </figure>
      </div>

      <div class="container container-narrow">
        <hr class="divider-wave" />

        <div class="story-stats">
          <div class="stat">
            <span class="stat-num">2020</span>
            <span class="stat-label">Gestartet</span>
          </div>
          <div class="stat">
            <span class="stat-num">100%</span>
            <span class="stat-label">Maßarbeit</span>
          </div>
          <div class="stat">
            <span class="stat-num">0</span>
            <span class="stat-label">Lange Wartezeiten</span>
          </div>
        </div>

      </div>
    </section>

    <section class="values">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Was uns wichtig ist</p>
          <h2>So arbeiten wir.</h2>
        </header>

        <div class="value-grid">
          <div class="value-item">
            <span class="value-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 12h18M3 12c0-4.97 4.03-9 9-9s9 4.03 9 9M3 12c0 4.97 4.03 9 9 9s9-4.03 9-9"/>
                <path d="M12 3v18"/>
              </svg>
            </span>
            <h4>Ehrliche Preise</h4>
            <p>Wir rechnen auf, was anfällt. Kein Aufschlag hinten dran, keine Überraschungen auf der Rechnung.</p>
          </div>

          <div class="value-item">
            <span class="value-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/>
              </svg>
            </span>
            <h4>Aufmaß direkt am Boot</h4>
            <p>Wir kommen zu Ihnen an den Liegeplatz, schauen uns alles an und nehmen Maß. Nur so passt es hinterher wirklich.</p>
          </div>

          <div class="value-item">
            <span class="value-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="9"/>
                <path d="M12 7v5l3 2"/>
              </svg>
            </span>
            <h4>Termine werden gehalten</h4>
            <p>Wir wissen, wann die Saison anfängt. Wenn wir einen Termin ausmachen, dann gilt der.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="story-cta">
      <div class="container container-narrow story-cta-inner">
        <h2>Sprechen wir kurz.</h2>
        <p class="lead">Wir kommen gerne zu Ihrem Boot und schauen uns an, was zu tun ist. Kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="btn btn-primary btn-arrow">Jetzt Kontakt aufnehmen</a>
      </div>
    </section>
  </article>

  <style>
    .story-header {
      position: relative;
      padding: var(--space-6) 0 var(--space-5);
      min-height: 40vh;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
      text-align: left;
      color: var(--color-white);
    }

    .story-header-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .story-header-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 82%;
      display: block;
    }

    .story-header-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        180deg,
        rgba(10, 28, 46, 0.35) 0%,
        rgba(10, 28, 46, 0.15) 40%,
        rgba(10, 28, 46, 0.75) 100%
      );
    }

    .story-header-content {
      position: relative;
      z-index: 1;
    }

    .story-header .eyebrow {
      color: #ffd89c;
    }

    .story-header h1 {
      color: var(--color-white);
      text-shadow: 0 2px 28px rgba(0, 0, 0, 0.45);
      margin: 0;
    }

    .story-header h1 em {
      color: var(--color-orange);
      font-style: normal;
    }

    .story-meta {
      font-size: var(--fs-sm);
      color: rgba(255, 255, 255, 0.85);
      letter-spacing: 0.04em;
      margin-top: var(--space-2);
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.4);
    }

    .story-body {
      padding: var(--space-6) 0 var(--space-7);
    }

    /* Zweispaltiges Layout: Text + großes Werkstatt-Bild */
    .story-layout {
      display: grid;
      grid-template-columns: 1fr minmax(340px, 0.82fr);
      gap: var(--space-6);
      align-items: center;
    }

    @media (max-width: 820px) {
      .story-layout {
        grid-template-columns: 1fr;
        gap: var(--space-4);
      }
    }

    .story-prose p {
      font-size: var(--fs-md);
      line-height: 1.75;
      color: var(--text-primary);
      max-width: none;
      margin-bottom: var(--space-3);
    }

    /* Großes Werkstatt-Bild mit versetztem Akzent-Block dahinter */
    .story-feature {
      position: relative;
      margin: 0;
    }

    .story-feature::before {
      content: '';
      position: absolute;
      right: -18px;
      bottom: -18px;
      width: 70%;
      height: 70%;
      background: var(--color-orange);
      opacity: 0.18;
      border-radius: 16px;
      z-index: 0;
    }

    .story-feature img {
      position: relative;
      z-index: 1;
      width: 100%;
      height: auto;
      aspect-ratio: 5 / 4;
      object-fit: cover;
      border-radius: 16px;
      box-shadow: var(--shadow-lift);
      display: block;
    }

    @media (max-width: 820px) {
      .story-feature {
        max-width: 560px;
        margin: 0 auto;
      }
    }

    .story-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      padding: var(--space-4) 0;
      margin-top: var(--space-4);
    }

    @media (max-width: 600px) {
      .story-stats {
        grid-template-columns: 1fr;
        text-align: center;
      }
    }

    .stat {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-num {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 800;
      color: var(--color-orange);
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .stat-label {
      font-size: var(--fs-xs);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-secondary);
      font-weight: 500;
    }

    /* Values */
    .values {
      background: var(--color-paper);
    }

    .section-head {
      text-align: center;
      margin-bottom: var(--space-5);
    }

    .section-head .eyebrow {
      justify-content: center;
    }

    .value-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }

    @media (max-width: 900px) {
      .value-grid {
        grid-template-columns: 1fr;
      }
    }

    .value-item {
      text-align: center;
    }

    .value-icon {
      display: inline-flex;
      width: 64px;
      height: 64px;
      align-items: center;
      justify-content: center;
      background: var(--color-white);
      color: var(--color-orange);
      border-radius: 50%;
      margin-bottom: var(--space-2);
      border: 1px solid rgba(224, 112, 53, 0.3);
    }

    .value-item h4 {
      margin-bottom: 0.5rem;
    }

    .value-item p {
      color: var(--text-secondary);
      font-size: var(--fs-sm);
      max-width: 38ch;
      margin: 0 auto;
    }

    /* CTA */
    .story-cta {
      padding: var(--space-6) 0;
      text-align: center;
    }

    .story-cta-inner h2 {
      margin-bottom: var(--space-2);
    }

    .story-cta-inner .lead {
      margin: 0 auto var(--space-3);
    }
  </style>
</BaseLayout>
