---
import BaseLayout from '../layouts/BaseLayout.astro';
const baseUrl = import.meta.env.BASE_URL;
const url = (p: string) => `${baseUrl}${p}`.replace('//', '/');
---

<BaseLayout
  title="Über uns"
  description="Peter Kowalewski — gelernter Bootsbauer, Segler und Angler. Die Geschichte hinter Piitoo's Bootsservice am Bodensee."
>
  <article class="story">
    <header class="story-header">
      <div class="container container-narrow">
        <p class="eyebrow reveal reveal-1">Die Geschichte</p>
        <h1 class="reveal reveal-2">
          Vom Wasser<br /><em>zur Werkstatt.</em>
        </h1>
        <p class="story-meta reveal reveal-3">Peter Kowalewski · Gelernter Bootsbauer · Seit 2020</p>
      </div>
    </header>

    <section class="story-body">
      <div class="container container-narrow">

        <div class="story-block">
          <p class="dropcap">
            Als gelernter Bootsbauer war mir früh klar, dass ich irgendwann auf eigene Rechnung
            arbeiten wollte. 2020 war es soweit — erst mit einer Nähmaschine in der Garage,
            heute mit einer eigenen Werkstatt in Oberteuringen.
          </p>
        </div>

        <hr class="divider-wave" />

        <div class="story-block">
          <h2>Aufgewachsen am Wasser</h2>
          <p>
            Ich bin am Bodensee groß geworden und war schon als Kind viel auf dem Wasser.
            Später dann als Angler, Segler und Ausbilder für Segel und Motor — der Bezug zu
            Booten hat mich nie losgelassen.
          </p>
        </div>

        <blockquote class="pull-quote">
          <p>„Boote sind mein Beruf. Aber ehrlich gesagt war ich immer schon lieber draußen auf dem Wasser als drinnen am Schreibtisch."</p>
        </blockquote>

        <div class="story-block">
          <h2>Wie es angefangen hat</h2>
          <p>
            Angefangen hat es mit einer Nähmaschine und den ersten Aufträgen von Bekannten.
            Kein großer Plan dahinter, einfach gute Arbeit gemacht.
          </p>
          <p>
            Heute habe ich eine eigene Werkstatt in Oberteuringen. Ich arbeite alleine,
            nehme mir Zeit für jeden Auftrag und komme für das Aufmaß immer direkt ans Boot.
          </p>
        </div>

        <hr class="divider-wave" />

        <div class="story-stats">
          <div class="stat">
            <span class="stat-num">2020</span>
            <span class="stat-label">Gestartet</span>
          </div>
          <div class="stat">
            <span class="stat-num">100%</span>
            <span class="stat-label">Maßarbeit</span>
          </div>
          <div class="stat">
            <span class="stat-num">1</span>
            <span class="stat-label">Mann, ein Wort</span>
          </div>
        </div>

      </div>
    </section>

    <section class="values">
      <div class="container">
        <header class="section-head">
          <p class="eyebrow">Was mir wichtig ist</p>
          <h2>So arbeite ich.</h2>
        </header>

        <div class="value-grid">
          <div class="value-item">
            <span class="value-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 12h18M3 12c0-4.97 4.03-9 9-9s9 4.03 9 9M3 12c0 4.97 4.03 9 9 9s9-4.03 9-9"/>
                <path d="M12 3v18"/>
              </svg>
            </span>
            <h4>Ehrliche Preise</h4>
            <p>Ich rechne auf, was anfällt. Kein Aufschlag hinten dran, keine Überraschungen auf der Rechnung.</p>
          </div>

          <div class="value-item">
            <span class="value-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/>
              </svg>
            </span>
            <h4>Aufmaß direkt am Boot</h4>
            <p>Ich komme zu Ihnen an den Liegeplatz, schaue mir alles an und nehme Maß. Nur so passt es hinterher wirklich.</p>
          </div>

          <div class="value-item">
            <span class="value-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="9"/>
                <path d="M12 7v5l3 2"/>
              </svg>
            </span>
            <h4>Termine werden gehalten</h4>
            <p>Ich weiß, wann die Saison anfängt. Wenn wir einen Termin ausmachen, dann gilt der.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="story-cta">
      <div class="container container-narrow story-cta-inner">
        <h2>Sprechen wir kurz.</h2>
        <p class="lead">Ich komme gerne zu Ihrem Boot und schaue mir an, was zu tun ist. Kostenlos und unverbindlich.</p>
        <a href={url('/kontakt/')} class="btn btn-primary btn-arrow">Jetzt Kontakt aufnehmen</a>
      </div>
    </section>
  </article>

  <style>
    .story-header {
      padding: var(--space-7) 0 var(--space-5);
      background: var(--color-paper);
      border-bottom: 1px solid rgba(17, 17, 17, 0.08);
      text-align: center;
    }

    .story-header .eyebrow {
      justify-content: center;
    }

    .story-meta {
      font-size: var(--fs-sm);
      color: var(--text-secondary);
      letter-spacing: 0.04em;
      margin-top: var(--space-2);
    }

    .story-body {
      padding: var(--space-5) 0 var(--space-7);
    }

    .story-block {
      margin-bottom: var(--space-5);
    }

    .story-block h2 {
      font-size: var(--fs-xl);
      margin-bottom: var(--space-2);
    }

    .story-block p {
      font-size: var(--fs-md);
      line-height: 1.7;
      color: var(--text-primary);
      max-width: none;
    }

    /* Drop cap */
    .dropcap::first-letter {
      font-family: var(--font-display);
      font-size: 4em;
      font-weight: 800;
      float: left;
      line-height: 0.85;
      margin: 0.07em 0.12em 0 0;
      color: var(--color-orange);
      font-style: normal;
    }

    .pull-quote {
      margin: var(--space-6) 0;
      padding-left: var(--space-3);
      border-left: 3px solid var(--color-orange);
    }

    .pull-quote p {
      font-family: var(--font-display);
      font-size: clamp(1.25rem, 2.5vw, 1.75rem);
      font-style: normal;
      font-weight: 600;
      line-height: 1.4;
      color: var(--color-ink);
      margin: 0;
      letter-spacing: -0.01em;
    }

    .story-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      padding: var(--space-4) 0;
      margin-top: var(--space-4);
    }

    @media (max-width: 600px) {
      .story-stats {
        grid-template-columns: 1fr;
        text-align: center;
      }
    }

    .stat {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-num {
      font-family: var(--font-display);
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 800;
      color: var(--color-orange);
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .stat-label {
      font-size: var(--fs-xs);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-secondary);
      font-weight: 500;
    }

    /* Values */
    .values {
      background: var(--color-paper);
    }

    .section-head {
      text-align: center;
      margin-bottom: var(--space-5);
    }

    .section-head .eyebrow {
      justify-content: center;
    }

    .value-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }

    @media (max-width: 900px) {
      .value-grid {
        grid-template-columns: 1fr;
      }
    }

    .value-item {
      text-align: center;
    }

    .value-icon {
      display: inline-flex;
      width: 64px;
      height: 64px;
      align-items: center;
      justify-content: center;
      background: var(--color-white);
      color: var(--color-orange);
      border-radius: 50%;
      margin-bottom: var(--space-2);
      border: 1px solid rgba(224, 112, 53, 0.3);
    }

    .value-item h4 {
      margin-bottom: 0.5rem;
    }

    .value-item p {
      color: var(--text-secondary);
      font-size: var(--fs-sm);
      max-width: 38ch;
      margin: 0 auto;
    }

    /* CTA */
    .story-cta {
      padding: var(--space-6) 0;
      text-align: center;
    }

    .story-cta-inner h2 {
      margin-bottom: var(--space-2);
    }

    .story-cta-inner .lead {
      margin: 0 auto var(--space-3);
    }
  </style>
</BaseLayout>
