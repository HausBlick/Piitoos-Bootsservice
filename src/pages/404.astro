---
import BaseLayout from '../layouts/BaseLayout.astro';
const baseUrl = import.meta.env.BASE_URL;
const url = (p: string) => `${baseUrl}${p}`.replace('//', '/');
---

<BaseLayout title="Seite nicht gefunden" description="Diese Seite existiert leider nicht.">
  <section class="notfound">
    <div class="container container-narrow notfound-inner">
      <p class="eyebrow">Fehler 404</p>
      <h1>Hier ist wohl<br /><em>Land unter.</em></h1>
      <p class="lead">
        Die gesuchte Seite gibt es nicht (mehr). Vielleicht hat sich ein Tippfehler
        eingeschlichen, oder die Seite ist umgezogen.
      </p>
      <div class="notfound-cta">
        <a href={url('/')} class="btn btn-primary">Zur Startseite</a>
        <a href={url('/kontakt/')} class="btn btn-ghost">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>

  <style>
    .notfound {
      padding: var(--space-7) 0;
      text-align: center;
    }

    .notfound-inner .eyebrow {
      justify-content: center;
    }

    .notfound h1 {
      margin-bottom: var(--space-3);
    }

    .notfound h1 em {
      font-style: normal;
      color: var(--color-orange);
    }

    .notfound .lead {
      margin: 0 auto var(--space-4);
    }

    .notfound-cta {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
  </style>
</BaseLayout>
