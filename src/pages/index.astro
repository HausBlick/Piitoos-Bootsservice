---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/hero-startseite.jpg';
const baseUrl = import.meta.env.BASE_URL;
const url = (p: string) => `${baseUrl}${p}`.replace('//', '/');
---

<BaseLayout title="Piitoo's Bootsservice">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <Image
        class="hero-img"
        src={heroImage}
        alt=""
        widths={[768, 1280, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <div class="hero-vignette"></div>
    </div>

    <div class="container hero-content">
      <p class="eyebrow reveal reveal-1">Persenning · Polster · Service</p>
      <h1 class="reveal reveal-2">
        Handwerk<br />
        <em>am Bodensee.</em>
      </h1>
      <p class="hero-lead reveal reveal-3">
        Persenninge und Polster nach Maß, Reparaturen und Bootsservice rund ums Boot.
        Peter Kowalewski aus Oberteuringen, am Bodensee, seit 2020.
      </p>
      <div class="hero-cta reveal reveal-4">
        <a href={url('/leistungen/')} class="btn btn-primary btn-arrow">Unsere Leistungen</a>
        <a href={url('/kontakt/')} class="btn btn-ghost btn-ghost-light">Kostenloses Angebot</a>
      </div>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span>scroll</span>
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- INTRO -->
  <section class="intro">
    <div class="container intro-grid">
      <div class="intro-mark" aria-hidden="true">
        <span class="big-quote">„</span>
      </div>
      <div class="intro-text">
        <p class="eyebrow">Über Piitoo</p>
        <h2>Gelernter Bootsbauer.<br /><em>Seit der Kindheit am Wasser.</em></h2>
        <p class="lead">
          Ich bin Peter — aufgewachsen am Bodensee, seit Jahren als Angler, Segler und
          Ausbilder unterwegs. 2020 habe ich angefangen, auf eigene Rechnung zu arbeiten.
          Inzwischen ist daraus eine richtige Werkstatt in Oberteuringen geworden.
        </p>
        <a href={url('/ueber-uns/')} class="link-arrow">Mehr über mich →</a>
      </div>
    </div>
  </section>

  <!-- LEISTUNGEN TEASER -->
  <section class="services-teaser">
    <div class="container">
      <header class="section-head">
        <p class="eyebrow">Was wir tun</p>
        <h2>Was ich mache.</h2>
      </header>

      <div class="service-cards">
        <article class="service-card">
          <span class="card-num">01</span>
          <h3>Persenning</h3>
          <p>Ich komme direkt zu Ihrem Boot, nehme Maß vor Ort und fertige alles passgenau. Neuanfertigung oder Reparatur.</p>
        </article>
        <article class="service-card">
          <span class="card-num">02</span>
          <h3>Polster</h3>
          <p>Neue Polster für Cockpit, Kajüte oder Steuerstand. Welches Material für Ihren Einsatzzweck passt, klären wir gemeinsam.</p>
        </article>
        <article class="service-card">
          <span class="card-num">03</span>
          <h3>Service</h3>
          <p>Pflege, Liegeplatzbetreuung, Wartung und Technikcoaching. Wenn etwas nicht stimmt, schaue ich es mir an.</p>
        </article>
      </div>

      <div class="services-cta">
        <a href={url('/leistungen/')} class="btn btn-ghost btn-arrow">Alle Leistungen ansehen</a>
      </div>
    </div>
  </section>

  <!-- CTA STREIFEN -->
  <section class="cta-strip">
    <div class="container cta-inner">
      <div>
        <p class="eyebrow eyebrow-light">Kostenlos &amp; unverbindlich</p>
        <h2 class="cta-headline">Kein langes Hin und Her.<br /><em>Ich schaue mir Ihr Boot einfach an.</em></h2>
      </div>
      <a href={url('/kontakt/')} class="btn btn-sunset btn-arrow">Jetzt anfragen</a>
    </div>
  </section>

  <style>
    /* ============ HERO ============ */
    .hero {
      position: relative;
      min-height: 88vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      color: var(--color-paper);
      padding: var(--space-7) 0 var(--space-6);
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .hero-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 40%;
      display: block;
    }

    .hero-vignette {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(10,28,46,0.25) 0%, rgba(10,28,46,0) 30%, rgba(10,28,46,0) 70%, rgba(10,28,46,0.5) 100%),
        radial-gradient(ellipse at left center, rgba(10,28,46,0.55) 0%, rgba(10,28,46,0) 60%);
    }

    .hero-content {
      position: relative;
      z-index: 1;
      max-width: 920px;
    }

    .hero h1 {
      color: var(--color-white);
      margin-bottom: var(--space-3);
      text-shadow: 0 2px 32px rgba(0, 0, 0, 0.4);
    }

    .hero h1 em {
      font-style: normal;
      font-weight: 800;
      color: var(--color-orange);
    }

    .hero-lead {
      font-size: clamp(1.125rem, 1.6vw, 1.35rem);
      line-height: 1.6;
      max-width: 540px;
      color: rgba(255, 255, 255, 0.88);
      margin-bottom: var(--space-4);
      text-shadow: 0 1px 12px rgba(0, 0, 0, 0.4);
    }

    .hero .eyebrow {
      color: #ffd89c;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn-ghost-light {
      border-color: rgba(246, 243, 238, 0.85);
      color: var(--color-paper);
      background: rgba(246, 243, 238, 0.06);
      backdrop-filter: blur(8px);
    }
    .btn-ghost-light:hover {
      background: var(--color-paper);
      color: var(--color-ink);
    }

    .hero-scroll {
      position: absolute;
      bottom: var(--space-3);
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      z-index: 1;
      color: rgba(246, 243, 238, 0.6);
      font-size: var(--fs-xs);
      letter-spacing: 0.25em;
      text-transform: uppercase;
    }

    .scroll-line {
      width: 1px;
      height: 32px;
      background: linear-gradient(180deg, rgba(246,243,238,0.6), transparent);
      animation: scrollHint 2s ease-in-out infinite;
    }

    @keyframes scrollHint {
      0%, 100% { transform: scaleY(1); opacity: 0.6; }
      50% { transform: scaleY(0.5) translateY(8px); opacity: 0.2; }
    }

    /* ============ INTRO ============ */
    .intro {
      background: var(--color-paper);
      padding: var(--space-7) 0;
    }

    .intro-grid {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: var(--space-5);
      align-items: start;
    }

    @media (max-width: 768px) {
      .intro-grid {
        grid-template-columns: 1fr;
        gap: var(--space-2);
      }
    }

    .big-quote {
      font-family: var(--font-display);
      font-size: 10rem;
      font-weight: 800;
      line-height: 0.7;
      color: var(--color-orange);
      font-style: normal;
      display: block;
      margin-top: -0.1em;
    }

    .link-arrow {
      display: inline-block;
      margin-top: var(--space-3);
      color: var(--color-ink);
      font-weight: 500;
      font-size: var(--fs-sm);
      border-bottom: 1px solid var(--color-sunset);
      padding-bottom: 2px;
      transition: all var(--transition);
    }
    .link-arrow:hover {
      color: var(--color-sunset);
      transform: translateX(4px);
    }

    /* ============ SERVICES TEASER ============ */
    .services-teaser {
      background: var(--color-paper);
      position: relative;
    }

    .section-head {
      text-align: center;
      margin-bottom: var(--space-6);
    }

    .section-head .eyebrow {
      justify-content: center;
    }

    .service-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
    }

    @media (max-width: 900px) {
      .service-cards {
        grid-template-columns: 1fr;
      }
    }

    .service-card {
      background: var(--color-white);
      padding: var(--space-4) var(--space-3);
      border-radius: var(--radius-md);
      border: 1px solid rgba(17, 17, 17, 0.08);
      transition: all var(--transition);
      position: relative;
      overflow: hidden;
    }

    .service-card::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: var(--color-orange);
      transform: scaleY(0);
      transform-origin: top;
      transition: transform var(--transition);
    }

    .service-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lift);
    }

    .service-card:hover::before {
      transform: scaleY(1);
    }

    .card-num {
      font-family: var(--font-display);
      font-style: normal;
      font-weight: 700;
      font-size: var(--fs-md);
      color: var(--color-orange);
      display: block;
      margin-bottom: var(--space-2);
    }

    .service-card h3 {
      margin-bottom: var(--space-2);
      font-size: var(--fs-lg);
    }

    .service-card p {
      color: var(--text-secondary);
      font-size: var(--fs-sm);
      margin: 0;
    }

    .services-cta {
      text-align: center;
      margin-top: var(--space-5);
    }

    /* ============ CTA STRIP ============ */
    .cta-strip {
      background: var(--color-charcoal);
      color: var(--color-white);
      position: relative;
      overflow: hidden;
    }

    .cta-strip::before {
      content: '';
      position: absolute;
      right: -200px;
      top: 50%;
      transform: translateY(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(224, 112, 53, 0.15) 0%, transparent 60%);
      pointer-events: none;
    }

    .cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      flex-wrap: wrap;
      position: relative;
    }

    .cta-headline {
      color: var(--color-white);
      margin: 0;
    }

    .eyebrow-light {
      color: var(--color-orange);
    }

    .btn-sunset {
      background: var(--color-orange);
      color: var(--color-white);
      font-weight: 700;
    }
    .btn-sunset:hover {
      background: var(--color-white);
      color: var(--color-charcoal);
      transform: translateY(-1px);
    }
  </style>
</BaseLayout>
