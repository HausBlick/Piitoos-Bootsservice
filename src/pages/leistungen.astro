---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import polsterImage from '../assets/polster-nah.jpg';
import verdeckImage from '../assets/verdeck-dlrg.jpg';
import sonnensegelImage from '../assets/sonnensegel-bav.jpg';
const baseUrl = import.meta.env.BASE_URL;
const url = (p: string) => `${baseUrl}${p}`.replace('//', '/');
---

<BaseLayout
  title="Leistungen"
  description="Maßgefertigte Persenninge, Polster, Reparaturen und Bootsservice. Pflege, Instandhaltung, Liegeplatzservice und Coaching am Bodensee."
>
  <!-- HEADER -->
  <header class="page-header">
    <div class="container container-narrow">
      <p class="eyebrow reveal reveal-1">Was wir tun</p>
      <h1 class="reveal reveal-2">
        Was wir<br /><em>anbieten.</em>
      </h1>
      <p class="lead reveal reveal-3">
        Persenninge, Polster, Reparaturen und Bootsservice — alles aus einer Hand,
        direkt am Bodensee. Wir nehmen uns Zeit für jeden Auftrag.
      </p>
    </div>
  </header>

  <!-- PERSENNING & POLSTER -->
  <section class="service-section service-section--alt">
    <div class="container service-block">
      <div class="service-meta">
        <span class="service-num">01</span>
        <p class="eyebrow">Maßanfertigung</p>
      </div>
      <div class="service-content">
        <h2>Persenning &amp; Polster.<br /><em>Passgenau am Boot.</em></h2>
        <p class="lead">
          Ob neu oder Reparatur: Wir kommen zu Ihrem Boot, schauen es uns an und
          geben Ihnen eine ehrliche Einschätzung. Kein Aufmaß vom Foto, kein Rätselraten.
        </p>

        <div class="service-process">
          <div class="process-step">
            <span class="process-dot"></span>
            <div>
              <h4>Kurzes Gespräch</h4>
              <p>Rufen Sie an oder schreiben Sie kurz. Wir hören uns an, was Sie brauchen.</p>
            </div>
          </div>
          <div class="process-step">
            <span class="process-dot"></span>
            <div>
              <h4>Aufmaß am Liegeplatz</h4>
              <p>Wir kommen direkt zu Ihrem Boot und nehmen Maß vor Ort. So passt es hinterher wirklich.</p>
            </div>
          </div>
          <div class="process-step">
            <span class="process-dot"></span>
            <div>
              <h4>Materialauswahl &amp; Angebot</h4>
              <p>Wir beraten Sie bei der Materialwahl und machen Ihnen ein konkretes Angebot. Kostenlos und unverbindlich.</p>
            </div>
          </div>
          <div class="process-step">
            <span class="process-dot"></span>
            <div>
              <h4>Fertigung &amp; Lieferung</h4>
              <p>Wir fertigen alles in unserer Werkstatt und bringen es pünktlich zum vereinbarten Termin.</p>
            </div>
          </div>
        </div>

        <ul class="service-list">
          <li>Vollpersenning, Kuchenbude und Cockpitpersenning</li>
          <li>Polster für Cockpit, Kajüte und Steuerstand</li>
          <li>Reparaturen an Nähten, Reißverschlüssen und Aufdoppelungen</li>
          <li>Sonderanfertigungen nach Absprache</li>
        </ul>
      </div>
    </div>

    <div class="container">
      <div class="work-gallery">
        <figure class="work-item">
          <Image
            src={verdeckImage}
            alt="Maßgefertigtes Kajütenverdeck mit klaren Fenstern im Innenraum eines Bootes"
            widths={[400, 640, 900]}
            sizes="(max-width: 700px) 100vw, 33vw"
            loading="lazy"
          />
          <figcaption>Persenning &amp; Verdeck nach Maß</figcaption>
        </figure>
        <figure class="work-item">
          <Image
            src={polsterImage}
            alt="Nahaufnahme eines neuen Bootspolsters aus beigem Kunstleder mit sauberer Ziernaht"
            widths={[400, 640, 900]}
            sizes="(max-width: 700px) 100vw, 33vw"
            loading="lazy"
          />
          <figcaption>Polster mit sauberer Ziernaht</figcaption>
        </figure>
        <figure class="work-item">
          <Image
            src={sonnensegelImage}
            alt="Dunkles, maßgefertigtes Sonnensegel gespannt über dem Vordeck eines Segelbootes"
            widths={[400, 640, 900]}
            sizes="(max-width: 700px) 100vw, 33vw"
            loading="lazy"
          />
          <figcaption>Sonnensegel für das Vordeck</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- SERVICE -->
  <section class="service-section">
    <div class="container service-block service-block--reverse">
      <div class="service-meta">
        <span class="service-num">02</span>
        <p class="eyebrow">Servicearbeiten</p>
      </div>
      <div class="service-content">
        <h2>Bootsservice.<br /><em>Wenn etwas gemacht werden muss.</em></h2>
        <p class="lead">
          Von der Saisonvorbereitung bis zum Liegeplatzservice: Wenn am Boot etwas
          anfällt, schauen wir es uns an und erledigen es.
        </p>

        <ul class="service-list service-list--columns">
          <li>Pflege und Reinigung</li>
          <li>Instandhaltung und Wartung</li>
          <li>Liegeplatzservice</li>
          <li>Reparaturen vor Ort</li>
          <li>Saisonvorbereitung</li>
          <li>Individuelle Leistungen nach Absprache</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- COACHING -->
  <section class="service-section service-section--alt">
    <div class="container service-block">
      <div class="service-meta">
        <span class="service-num">03</span>
        <p class="eyebrow">Coaching &amp; Beratung</p>
      </div>
      <div class="service-content">
        <h2>Coaching an Bord.<br /><em>Direkt auf dem Wasser.</em></h2>
        <p class="lead">
          Wir haben viele Jahre als Ausbilder für Segel und Motor gearbeitet. Wenn Sie
          etwas über Ihr Boot wissen wollen, fragen Sie einfach.
        </p>

        <ul class="service-list service-list--columns">
          <li>Takelage und Rigg</li>
          <li>Wasser und Strom an Bord</li>
          <li>Ausrüstung und Sicherheit</li>
          <li>Praktische Tipps für Einsteiger</li>
          <li>Individuelle Themen nach Absprache</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-strip">
    <div class="container cta-inner">
      <div>
        <p class="eyebrow eyebrow-light">Kostenlos &amp; unverbindlich</p>
        <h2 class="cta-headline">Sagen Sie uns,<br /><em>was Sie brauchen.</em></h2>
      </div>
      <a href={url('/kontakt/')} class="btn btn-sunset btn-arrow">Angebot anfragen</a>
    </div>
  </section>

  <style>
    .page-header {
      padding: var(--space-7) 0 var(--space-5);
      text-align: center;
      background: var(--color-paper);
      border-bottom: 1px solid rgba(17, 17, 17, 0.08);
    }

    .page-header .eyebrow {
      justify-content: center;
    }

    .page-header .lead {
      margin: var(--space-3) auto 0;
    }

    .service-section {
      padding: var(--space-6) 0;
    }

    .service-section--alt {
      background: var(--color-paper);
    }

    .work-gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-3);
      margin-top: var(--space-5);
    }

    @media (max-width: 700px) {
      .work-gallery {
        grid-template-columns: 1fr;
      }
    }

    .work-item {
      margin: 0;
    }

    .work-item img {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      border-radius: var(--radius-md);
      display: block;
      box-shadow: var(--shadow-lift);
    }

    .work-item figcaption {
      margin-top: var(--space-2);
      font-size: var(--fs-sm);
      color: var(--text-secondary);
      text-align: center;
    }

    .service-block {
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: var(--space-5);
      align-items: start;
    }

    .service-block--reverse {
      grid-template-columns: 1fr 200px;
    }

    .service-block--reverse .service-meta {
      grid-column: 2;
      grid-row: 1;
      text-align: right;
    }

    .service-block--reverse .service-content {
      grid-column: 1;
      grid-row: 1;
    }

    @media (max-width: 900px) {
      .service-block,
      .service-block--reverse {
        grid-template-columns: 1fr;
        gap: var(--space-3);
      }
      .service-block--reverse .service-meta,
      .service-block--reverse .service-content {
        grid-column: 1;
        text-align: left;
      }
      .service-block--reverse .service-meta {
        grid-row: auto;
      }
    }

    .service-num {
      font-family: var(--font-display);
      font-style: normal;
      font-weight: 800;
      font-size: clamp(3.5rem, 7vw, 5rem);
      line-height: 1;
      color: var(--color-orange);
      display: block;
      margin-bottom: var(--space-2);
      letter-spacing: -0.04em;
    }

    .service-content h2 {
      margin-bottom: var(--space-3);
    }

    .service-process {
      margin: var(--space-4) 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      padding-left: var(--space-2);
      border-left: 1px solid rgba(17, 17, 17, 0.12);
    }

    .process-step {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: var(--space-2);
      align-items: start;
      position: relative;
    }

    .process-dot {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--color-white);
      border: 2px solid var(--color-orange);
      margin-top: 0.45rem;
      margin-left: calc(-1 * var(--space-2) - 8px);
      flex-shrink: 0;
    }

    .service-section--alt .process-dot {
      background: var(--color-paper);
    }

    .process-step h4 {
      margin: 0 0 0.25rem;
      font-size: var(--fs-md);
    }

    .process-step p {
      color: var(--text-secondary);
      font-size: var(--fs-sm);
      margin: 0;
    }

    .service-list {
      list-style: none;
      padding: 0;
      margin: var(--space-3) 0 0;
    }

    .service-list li {
      padding: 0.85rem 0;
      border-bottom: 1px solid rgba(17, 17, 17, 0.08);
      font-size: var(--fs-base);
      position: relative;
      padding-left: 1.75rem;
    }

    .service-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      width: 12px;
      height: 2px;
      background: var(--color-orange);
      transform: translateY(-50%);
    }

    .service-list--columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 var(--space-3);
    }

    @media (max-width: 600px) {
      .service-list--columns {
        grid-template-columns: 1fr;
      }
    }


    /* CTA strip */
    .cta-strip {
      background: var(--color-charcoal);
      color: var(--color-white);
      position: relative;
      overflow: hidden;
    }

    .cta-strip::before {
      content: '';
      position: absolute;
      right: -200px;
      top: 50%;
      transform: translateY(-50%);
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(224, 112, 53, 0.15) 0%, transparent 60%);
      pointer-events: none;
    }

    .cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      flex-wrap: wrap;
      position: relative;
    }

    .cta-headline {
      color: var(--color-white);
      margin: 0;
    }

    .eyebrow-light {
      color: var(--color-orange);
    }

    .btn-sunset {
      background: var(--color-orange);
      color: var(--color-white);
      font-weight: 700;
    }
    .btn-sunset:hover {
      background: var(--color-white);
      color: var(--color-charcoal);
      transform: translateY(-1px);
    }
  </style>
</BaseLayout>
